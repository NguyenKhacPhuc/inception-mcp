# GitHub credentials — a Personal Access Token (classic) with `repo` scope, or a fine-grained PAT scoped to your target repo.
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Target repo in `owner/name` form. The MCP reads issues + markdown from here.
GH_REPO=NguyenKhacPhuc/mindnote

# Default branch to read markdown from (PRD, decisions, etc.). Issues are branch-independent.
GH_BRANCH=main

# Bearer token for client → MCP auth. Generate with `openssl rand -hex 32`.
# Each dev's Claude Code MCP config carries this in the Authorization header.
MCP_TOKEN=replace-me-with-a-strong-random-string

# HTTP port. Railway sets PORT automatically.
PORT=8787

# Cache TTL for GitHub responses, in seconds. Keep small so claim/release feels live.
CACHE_TTL_SECONDS=30
